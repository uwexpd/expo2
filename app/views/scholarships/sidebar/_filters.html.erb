<div id="scholarship-filters">

<h5><i class="material-icons vertical_top">filter_list</i> Filters</h5>

<%= search_form_for @search, html: { id: 'scholarship-filter-form' } do |f| %>
  <%#= f.submit 'Filter', class: 'btn' %>
  <%#= link_to "CLEAR FILTERS", scholarships_path, class: 'clear_filter' %>

  <%# ── Deadline Month ─────────────────────────────────────────────────── %>
  <%# Direct Ransack _in predicate — Select2 applied straight to this field %>
  <p><strong>Deadline Month</strong></p>
  <%= f.select :scholarship_monthly_deadlines_deadline_month_in,
        (1..12).map { |m| [Date::MONTHNAMES[m], m] },
        { include_blank: false },
        { multiple: true,
          id: 'deadline_month_select',
          style: 'width:100%' } %>

  <%# ── Academic Standing ──────────────────────────────────────────────── %>
  <%# Raw inputs reading from params[:q] directly — NOT from @search,      %>
  <%# because @search is built from q_for_ransack (which has _true deleted) %>
  <div id="standing-ransack-inputs" style="display:none">
    <input type="checkbox" id="cb_freshman"   name="q[freshman_true]"   value="1" <%= 'checked' if params.dig(:q, 'freshman_true')   == '1' %>>
    <input type="checkbox" id="cb_sophomore"  name="q[sophomore_true]"  value="1" <%= 'checked' if params.dig(:q, 'sophomore_true')  == '1' %>>
    <input type="checkbox" id="cb_junior"     name="q[junior_true]"     value="1" <%= 'checked' if params.dig(:q, 'junior_true')     == '1' %>>
    <input type="checkbox" id="cb_senior"     name="q[senior_true]"     value="1" <%= 'checked' if params.dig(:q, 'senior_true')     == '1' %>>
    <input type="checkbox" id="cb_fifth_year" name="q[fifth_year_true]" value="1" <%= 'checked' if params.dig(:q, 'fifth_year_true') == '1' %>>
    <input type="checkbox" id="cb_graduate"   name="q[graduate_true]"   value="1" <%= 'checked' if params.dig(:q, 'graduate_true')   == '1' %>>
  </div>

  <p><strong>Academic Standing</strong></p>
  <select id="academic_standing_select" multiple="multiple" style="width:100%">
    <option value="freshman">1st Year Undergraduate</option>
    <option value="sophomore">2nd Year Undergraduate</option>
    <option value="junior">3rd Year Undergraduate</option>
    <option value="senior">4th Year Undergraduate</option>
    <option value="fifth_year">5th Year Undergraduate</option>
    <option value="graduate">Alumni and/or Graduate Student</option>
  </select>

  <%# ── Citizenship ────────────────────────────────────────────────────── %>
  <%# Ransack hidden inputs – synced by JS before submit %>
  <div id="citizenship-ransack-inputs" style="display:none">
    <input type="checkbox" id="cb_us_citizen"          name="q[us_citizen_true]"          value="1" <%= 'checked' if params.dig(:q, 'us_citizen_true')          == '1' %>>
    <input type="checkbox" id="cb_permanent_resident"  name="q[permanent_resident_true]"  value="1" <%= 'checked' if params.dig(:q, 'permanent_resident_true')  == '1' %>>
    <input type="checkbox" id="cb_other_visa_status"   name="q[other_visa_status_true]"   value="1" <%= 'checked' if params.dig(:q, 'other_visa_status_true')   == '1' %>>
    <input type="checkbox" id="cb_hb_1079"             name="q[hb_1079_true]"             value="1" <%= 'checked' if params.dig(:q, 'hb_1079_true')             == '1' %>>
  </div>

  <p><strong>Citizenship</strong></p>
  <select id="citizenship_select" multiple="multiple" style="width:100%">
    <option value="us_citizen">US Citizen</option>
    <option value="permanent_resident">Permanent Resident</option>
    <option value="other_visa_status">International or Other Visa Status</option>
    <option value="hb_1079">Undocumented</option>
  </select>

  <%# ── Financial Need ─────────────────────────────────────────────────── %>
  <p><strong>Financial Need</strong></p>
  <p>
    <label>
      <%= f.check_box :need_based_true, {class: 'filled-in'}, '1', '' %>
      <span>Requiring Financial Need</span>
    </label>
  </p>

  <%# ── Residency ───────────────────────────────────────────────────────── %>
  <p><strong>Residency</strong></p>
  <p>
    <label>
      <%= f.check_box :resident_true, {class: 'filled-in'}, '1', '' %>
      <span>Requiring Washington Residency</span>
    </label>
  </p>

  <%# ── Scholarship Type ────────────────────────────────────────────────── %>
  <p><strong>Scholarship Type</strong></p>

  <label>Field(s) of Interest or Study</label>
  <%= f.collection_select :categories_category_id_in,
        Category.where(parent_id: 0).where.not(id: [188, 189]),
        :id, :name,
        { include_blank: 'Any' },
        { multiple: true, class: 'chosen-select' } %>

  <label>Support Activities</label>
  <%= f.collection_select :types_type_id_in,
        Type.all,
        :id, :name,
        { include_blank: 'Any' },
        { multiple: true, class: 'chosen-select' } %>

  <p>
    <label>
      <%= f.check_box :is_departmental_true, {class: 'filled-in'}, '1', '' %>
      <span>Offered by UW</span>
    </label>
  </p>

  <p>
    <label>
      <%= f.check_box :gap_year_true, {class: 'filled-in'}, '1', '' %>
      <span>Support Gap Year Experiences</span>
    </label>
  </p>
  <p>
    <label>
      <%= f.check_box :graduate_school_true, {class: 'filled-in'}, '1', '' %>
      <span>Support Graduate Studies</span>
    </label>
  </p>
  
  <%= f.submit 'Filter', class: 'btn' %>
  <%= link_to "CLEAR FILTERS", scholarships_path, class: 'clear_filter' %>

<% end %>

</div><%# ── end #scholarship-filters ── %>