<% if @student %>
  $("#student_name").show();
  $("#student_name").html("<%= j(render(partial: "student_name", object: @student)) %>");
  $("#student_id_form_error").html("");

  $("#activity_system_key").val("<%= j(@student.system_key.to_s) %>");
  $("#student_id_form").hide();
<% else %>
  $("#student_id_form_error").html("Could not find a student record using that ID. Please try again.");
  $("#student_id").focus().select();
<% end %>