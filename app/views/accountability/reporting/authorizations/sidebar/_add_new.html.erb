<ul class="collection with-header">
 <li class="collection-header"><strong>Add New User <i class='mi'>add_circle</i></strong></li>
 	<div class='card-content'>
		<p style='padding-bottom: 0.5rem'>Enter a user's <strong>UW NetID</strong> to give them access to report and edit for your department:</p>

		<%= form_tag accountability_reporting_authorizations_path(@year), remote: true do %>
		    <%= text_field_tag :uw_netid, nil, class: 'browser-default' %>
		    <br><br>
		    <%= submit_tag "Authorize", class: 'btn' %>

		    <div class="input" style="margin-top: 0.75rem;">
		     <span class="error-message" id="add_user_error"></span>
		     <span class="success-message" id="add_user_success"></span>
		    </div>
		<% end %>
	</div>
</ul>