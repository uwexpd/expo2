<ul class="collection with-header">
  <li class="collection-header">
    <strong>2. Add Other Courses if Needed</strong>
  </li>
  
  <li class="collection-item" style="padding-left: 1rem">
    
      Enter a list of courses to add, one per line.
      <br>
      <small class="light">Examples: BIOL 499 A, GEN ST 350</small>    

    <%= form_with url: mass_add_accountability_reporting_courses_path(@year),
                  scope: :activity,
                  local: true do |course_form| %>

      <span id="course_form_error" class="error-message"></span>

      <%= text_area_tag :course_abbrevs,
                        nil,
                        rows: 5,
                        style: "width:95%; height: auto" %>

      <%= button_tag "<i class='mi'>add</i> Add Courses".html_safe, 
               type: 'submit', 
               class: 'btn small' %>

    <% end %>
  </li>
</ul>