<% hide_college_title ||= false %>

<tr class='sticky'>
  <th rowspan="2"><%= "College" unless hide_college_title %></th>
  <th rowspan="2"><%= "Department" unless hide_college_title %></th>
  <% @report_objects.each do |activity_type, report| %>
    <th colspan="3" class="small center">
      <%= activity_type.title %>
      <% unless report.finalized? %>
        <br><span class="status_tag red">DRAFT</span>
      <% end %>
    </th>
  <% end %>
</tr>
<tr class="sticky small center">
  <% @activity_types.each do |activity_type| %>
    <th>Number of students</th>
    <th>Number of student-quarters</th>
    <th>Number of hours</th>
  <% end %>
</tr>