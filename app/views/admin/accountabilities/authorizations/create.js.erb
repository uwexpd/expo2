<% key = params[:authorizable_key].to_s %>
<% inline_error_sel = "#auth_error_#{key}" %>
<% inline_overlay_sel = "#inline_add_form_#{key}" %>

<% if @error.present? %>
  // Inline form error (if this request came from an inline row)
  if ($("<%= j inline_error_sel %>").length) {
    $("<%= j inline_error_sel %>").html("<%= j @error %>").show();
    $("<%= j inline_overlay_sel %>").show(); // keep it open so user sees the message
  } else {
    // Fallback to global error area (for the non-inline UI)
    $("#add_user_error").html("<%= j @error %>");
    $("#add_user_success").html("");
  }
<% else %>
  // Clear inline error if present
  if ($("<%= j inline_error_sel %>").length) {
    $("<%= j inline_error_sel %>").html("").hide();
  }
  $("#add_user_error").html("");

  $("#add_user_success").html(
    "Successfully authorized <strong><%= j params[:uw_netid].to_s %></strong> for " +
    "<strong><%= j @department.name %></strong>."
  );

  if ($("#global_overlay").length) {
    $("#add_user_success").insertAfter("#global_overlay");
  }

  var rowSelector = "#row_<%= @department.class.to_s %>_<%= @department.id.to_s %>";

  if ($(rowSelector).length) {
    $(rowSelector).replaceWith("<%= j(render partial: 'admin/accountabilities/authorizations/department', object: @department, locals: { authorizations: @authorizations }) %>");
  } else {
    $("#department_authorizations_tbody").prepend("<%= j(render partial: 'admin/accountabilities/authorizations/department', object: @department, locals: { authorizations: @authorizations }) %>");
  }

  // Clear inputs: handle BOTH inline and global forms
  var inlineNetid = "#uw_netid_<%= j key %>";
  if ($(inlineNetid).length) {
    $(inlineNetid).val("");
  } else {
    $("#uw_netid").val("");
    $("#department_search").val(null).trigger("change");
    $("#authorizable_key").val("");
  }

  setTimeout(function () {
    var $row = $(rowSelector);
    if (!$row.length) return;

    $row.addClass("flash-highlight");
    setTimeout(function () { $row.removeClass("flash-highlight"); }, 3000);

    try {
      $row[0].scrollIntoView({ behavior: "smooth", block: "center" });
    } catch (e) {
      var top = $row.offset().top - 120;
      $("html, body").animate({ scrollTop: top }, 250);
    }

    var $focusTarget = $row.find("a, button, input, select, textarea").first();
    if ($focusTarget.length) {
      $focusTarget.focus();
    } else {
      $row.attr("tabindex", "-1").focus();
    }
  }, 0);
<% end %>