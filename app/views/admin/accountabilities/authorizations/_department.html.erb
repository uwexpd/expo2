<tr id="row_<%= department.class.to_s %>_<%= department.id.to_s %>">

	<td>
		<%= department.name %>
	</td>

	<td>
		<small class="light"><%= "#{department.class.to_s} ID #{department.id.to_s}" %></small>
	</td>

	<td>
		<ul class="inline">
		<% authorizations.each do |authorization| %>
			<li class="deleteable tag" id="authorization_<%= authorization.id.to_s %>">
				<%= authorization.login %>
				<%= link_to "<i class='mi md-16'>close</i>".html_safe, admin_accountability_authorization_path(authorization),
		                method: :delete,
		                remote: true,
		                data: { confirm: "Are you sure?", disable_with: "Deleting..."} %>				
			</li>
		<% end %>
		</ul>
	</td>

	<td>		
		<%= link_to "<i class='mi'>person_add</i>".html_safe, "#", 
			data: { link_toggle: "#inline_add_form_#{department.class.to_s}_#{department.id.to_s}" } %>

		<div class="overlay box" id="inline_add_form_<%= department.class.to_s %>_<%= department.id.to_s %>" style="display:none">
			<%= form_tag admin_accountability_authorizations_path, method: :post, remote: true do %>
				<strong>Authorize UW NetID:</strong><br>
				<%= text_field_tag "uw_netid", nil, 
									id: "uw_netid_#{department.class.to_s}_#{department.id.to_s}", 
									class: 'browser-default' %>
				<%= hidden_field_tag :authorizable_key, "#{department.class.to_s}_#{department.id.to_s}", 
									:id => "authorizable_key_#{rand(10000)}" %><br>
			    <%= submit_tag "Authorize", class: 'btn small flat' %>
			<% end %>			
		</div>
	</td>
</tr>
