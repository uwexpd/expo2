<% if @error.present? %>
  $("#add_user_error").html("<%= j @error %>");
  $("#add_user_success").html("");
<% else %>
  $("#add_user_error").html("");
  $("#add_user_success").html("Successfully authorized <%= j params[:uw_netid].to_s %>");

  // Move the overlay out of the way before we start deleting things
  if ($("#global_overlay").length) {
    $("#add_user_success").insertAfter("#global_overlay");
  }

  var rowSelector = "#row_<%= @department.class.to_s %>_<%= @department.id.to_s %>";

  if ($(rowSelector).length) {
    $(rowSelector).replaceWith("<%= j(render partial: 'admin/accountability/authorizations/department', object: @department, locals: { authorizations: @authorizations }) %>");
  } else {
    $("#department_authorizations_tbody").prepend("<%= j(render partial: 'admin/accountability/authorizations/department', object: @department, locals: { authorizations: @authorizations }) %>");
  }

  $("#uw_netid").val("");

  // highlight effect (requires jQuery UI). If you don't have it, I can give a CSS-only alternative.
  if ($(rowSelector).length) {
    $(rowSelector).addClass("flash-highlight");
    setTimeout(function () {
      $(rowSelector).removeClass("flash-highlight");
    }, 1500);
  }
<% end %>